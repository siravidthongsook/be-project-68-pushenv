          "raw": "/*{\r\n    \"name\" : \"admin2\",\r\n    \"telephone\": \"0856738768\",\r\n    \"email\": \"{{$randomExampleEmail}}\",\r\n    \"password\": \"12345678\",\r\n    \"role\" : \"admin\"\r\n}*/\r\n{\r\n    \"name\" : \"{{$randomFirstName}}\",\r\n    \"telephone\": \"{{customRandomPhone}}\",\r\n    \"email\": \"{{$randomExampleEmail}}\",\r\n    \"password\": \"12345678\",\r\n    \"role\": \"user\"\r\n}",
