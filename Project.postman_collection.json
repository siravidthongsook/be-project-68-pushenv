      "name": "User Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomDigitString = Math.floor(100000000 + Math.random() * 900000000).toString();\r",
              "const validPhoneNumber = \"0\" + randomDigitString;\r",
              "\r",
              "// Save it as a temporary variable for this specific request\r",
              "pm.variables.set(\"customRandomPhone\", validPhoneNumber);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const requestBody = JSON.parse(pm.request.body.raw);\r",
              "const new_user_email = requestBody.email;\r",
              "const new_user_password = requestBody.password;\r",
              "\r",
              "pm.environment.set(\"global_user_email\", new_user_email);\r",
              "pm.environment.set(\"global_user_password\", new_user_password);\r",
              "\r",
              "pm.execution.setNextRequest(\"User Login\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
